{
  "name": "@agentstow/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "bun x svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "bun x svelte-check --tsconfig ./tsconfig.json",
    "test": "bun run test:browser && bun run test:e2e",
    "test:browser": "vitest --config ./vitest.config.ts --run",
    "test:e2e": "playwright test --config ./playwright.config.ts",
    "test:e2e:install-browser": "bun x playwright install chromium",
    "test:e2e:ui": "playwright test --config ./playwright.config.ts --ui"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.7",
    "@codemirror/commands": "^6.9.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-jinja": "^6.0.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.11.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@tanstack/svelte-virtual": "^3.13.22",
    "@lezer/highlight": "^1.2.1",
    "bits-ui": "^2.15.5",
    "codemirror": "^6.0.1",
    "diff": "^8.0.2",
    "dompurify": "^3.2.6",
    "marked": "^17.0.4",
    "paneforge": "^1.0.2",
    "svelte": "^5.53.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.5.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.1.0"
  }
}
