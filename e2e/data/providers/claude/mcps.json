{
  "mcpServers": {
    "filesystem": {
      "transport": {
        "kind": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "./docs",
          "./notes"
        ]
      },
      "env": [
        {
          "key": "LOG_LEVEL",
          "binding": {
            "kind": "literal",
            "value": "info"
          }
        },
        {
          "key": "FIXTURE_NAME",
          "binding": {
            "kind": "literal",
            "value": "claude-provider-fixture"
          }
        }
      ]
    }
  }
}
