model = "gpt-5-codex"
project_doc_max_bytes = 65536
project_doc_fallback_filenames = ["AGENTS.md", "TEAM_GUIDE.md"]

[shell_environment_policy]
inherit = "core"
set = { AGENTSTOW_PROVIDER = "{{ env.PROVIDER_NAME }}", README_RENDER_MODE = "{{ env.README_RENDER_MODE }}" }
include_only = ["PATH", "HOME", "SHELL", "LANG", "TERM", "GITHUB_TOKEN", "TAVILY_API_KEY", "AGENTSTOW_TENANT"]

[mcp_servers.filesystem]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-filesystem", "./docs", "./specs"]
cwd = "."
env_vars = ["GITHUB_TOKEN"]
startup_timeout_sec = 20
tool_timeout_sec = 45
enabled = true
required = false
enabled_tools = ["read_file", "list_dir"]

[mcp_servers.tavily]
url = "https://mcp.tavily.com/mcp"
bearer_token_env_var = "TAVILY_API_KEY"
http_headers = { X-Agent = "agentstow-e2e" }
env_http_headers = { X-Tenant = "AGENTSTOW_TENANT" }
startup_timeout_sec = 20
tool_timeout_sec = 45
enabled = true
required = false
enabled_tools = ["search", "extract"]
disabled_tools = ["crawl"]
