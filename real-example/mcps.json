{
  "mcpServers": {
    "filesystem": {
      "transport": {
        "kind": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "."
        ]
      },
      "env": [
        {
          "key": "NODE_ENV",
          "binding": {
            "kind": "literal",
            "value": "production"
          }
        },
        {
          "key": "DEBUG",
          "binding": {
            "kind": "literal",
            "value": "mcp:*"
          }
        }
      ]
    },
    "fetch": {
      "transport": {
        "kind": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-fetch"
        ]
      },
      "env": [
        {
          "key": "HTTP_PROXY",
          "binding": {
            "kind": "literal",
            "value": "http://127.0.0.1:7890"
          }
        }
      ]
    },
    "weather_http": {
      "transport": {
        "kind": "http",
        "url": "https://api.example.com/mcp",
        "headers": {
          "X-Workspace": "agentstow-demo"
        }
      },
      "env": [
        {
          "key": "WEATHER_API_TOKEN",
          "binding": {
            "kind": "env",
            "var": "WEATHER_API_TOKEN"
          }
        }
      ]
    }
  }
}
